<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><title>VRELOX Magazine</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond&family=Inter&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-container">
        <header>
            <div class="top-bar">
                <div>⚡</div>
                <div class="brand-logo"><h1>VRELOX</h1></div>
                <div><a href="/logout" style="color:var(--text-muted); font-size:12px; text-decoration:none;">Logout</a></div>
            </div>
            <div class="nav-categories">
                <a href="#" class="active">Home</a><a href="#">Fashion</a><a href="#">Business</a><a href="#">Luxury</a>
            </div>
        </header>

        <!-- Dynamic Hero Section -->
        <% const hero = articles.find(a => a.isHero); if(hero) { %>
            <section class="hero-section" style="background-image: url('<%= hero.imageUrl %>');">
                <div class="hero-overlay"></div>
                <div class="hero-content">
                    <span class="tag"><%= hero.category %></span>
                    <h2 class="hero-title"><%= hero.title %></h2>
                    <p style="font-size:12px; color:#c4c4c6;"><%= hero.description %></p>
                </div>
            </section>
        <% } %>

        <!-- Dynamic Latest Stories -->
        <section>
            <h3 style="padding:0 16px 10px; font-size:13px; text-transform:uppercase; letter-spacing:1px;">Latest Stories</h3>
            <div class="stories-scroll">
                <% articles.filter(a => !a.isHero).forEach(article => { %>
                    <div class="story-card">
                        <img src="<%= article.imageUrl %>" alt="">
                        <div class="story-overlay">
                            <span class="tag"><%= article.category %></span>
                            <h4 style="font-size:11px; font-weight:400;"><%= article.title %></h4>
                            <span style="font-size:8px; color:var(--text-muted);"><%= article.readTime %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>

        <nav class="bottom-nav">
            <a href="#" class="nav-item active">Home</a>
            <a href="#" class="nav-item">Magazine</a>
            <a href="#" class="nav-item">Profile</a>
        </nav>
    </div>
</body>
</html>
